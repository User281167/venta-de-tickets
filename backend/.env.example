# Prisma: DATABASE_URL (pooled, port 6543) for runtime queries via pgBouncer
# Prisma: DIRECT_URL (direct, port 5432) for migrations (bypasses pgBouncer)
# See: https://supabase.com/docs/guides/integrations/prisma

DATABASE_URL="postgresql://postgres:[PASSWORD]@[PROJECT].supabase.co:6543/postgres?pgbouncer=true&connection_limit=1"
DIRECT_URL="postgresql://postgres:[PASSWORD]@[PROJECT].supabase.co:5432/postgres"
SUPABASE_URL=""
SUPABASE_ANON_KEY=""
CORS_ORIGIN="http://localhost:3000"
SUPER_ADMIN_ID=<uuid-de-supabase-auth>
SUPER_ADMIN_EMAIL=admin@universidad.edu
SUPABASE_SERVICE_ROLE_KEY=""
SUPABASE_JWT_SECRET=tu-jwt-secret-del-dashboard
QR_JWT_SECRET=<min-32-chars-secret-key>
MERCADOPAGO_ACCESS_TOKEN=tu-access-token
