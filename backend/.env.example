# Prisma: DATABASE_URL (pooled, port 6543) for runtime queries via pgBouncer
# Prisma: DIRECT_URL (direct, port 5432) for migrations (bypasses pgBouncer)
# See: https://supabase.com/docs/guides/integrations/prisma

# Connect to Postgres via the shared transaction-mode pooler (IPv4-only)
DATABASE_URL=postgresql://postgres...
# Connect to Postgres via the shared session-mode pooler (used for migrations)
DIRECT_URL=postgresql://postgres...
SUPABASE_URL=https://URL.supabase.co
SUPABASE_ANON_KEY=ANON_KEY
CORS_ORIGIN=http://localhost:3000
SUPABASE_SERVICE_ROLE_KEY=SERVICE_ROLE_KEY
QR_JWT_SECRET=SHA256_secret
CONFIRMATION_JWT_SECRET=SHA256_secret_different_from_qr
CONFIRMATION_TOKEN_TTL=30m
CONFIRMATION_LINK_BASE_URL=http://localhost:3000
API_URL=http://localhost:3001
MERCADOPAGO_ACCESS_TOKEN=YOUR_ACCESS_TOKEN
MERCADOPAGO_WEBHOOK_SECRET=YOUR_WEBHOOK_SECRET
