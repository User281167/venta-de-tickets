generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  super_admin
  admin
  checker
  client
}

enum TicketStatus {
  reserved
  paid
  pending_confirmation
  confirmed
  used
  cancelled
  expired
}

enum PaymentStatus {
  pending
  completed
  failed
  refunded
}

enum DiscountType {
  percentage
  fixed
}

enum PolicyType {
  privacy_policy
  terms_of_service
}

enum TicketTypeStatus {
  enabled
  disabled
  blocked
}

model User {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  cedula    String?    @unique @db.VarChar(20)
  fullName  String    @map("full_name") @db.VarChar(150)
  address   String?   @db.Text
  dateOfBirth DateTime? @map("date_of_birth") @db.Date
  email     String    @unique @db.VarChar(255)
  phone     String?   @db.VarChar(20)
  role      UserRole
  isActive  Boolean   @default(true) @map("is_active")
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz
  egresado  Boolean   @default(false) @map("egresado")

  privacyAcceptances PrivacyAcceptance[]
  tickets            Ticket[]
  payments           Payment[]
  createdDiscounts   DiscountCode[]     @relation("CreatedBy")
  createdPayments    Payment[]          @relation("CreatedPayments")
  checkedInTickets   Ticket[]           @relation("CheckedInBy")

  @@map("users")
}

model PrivacyAcceptance {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId        String     @map("user_id") @db.Uuid
  policyVersion String     @map("policy_version") @db.VarChar(20)
  policyType    PolicyType @map("policy_type")
  acceptedAt    DateTime   @default(now()) @map("accepted_at") @db.Timestamptz
  ipAddress     String     @map("ip_address") @db.Inet
  userAgent     String     @map("user_agent")
  content       String?

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@map("privacy_acceptances")
}

model TicketType {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name          String   @db.VarChar(100)
  description   String?
  price         Decimal  @db.Decimal(12, 2)
  quantityTotal Int      @map("quantity_total")
  quantitySold  Int      @default(0) @map("quantity_sold")
  maxPerUser    Int?     @map("max_per_user")
  saleEndsAt    DateTime? @map("sale_ends_at") @db.Timestamptz
  status        TicketTypeStatus  @default(enabled) @map("status")
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt     DateTime @updatedAt @map("updated_at") @db.Timestamptz

  tickets Ticket[]

  @@map("ticket_types")
}

model DiscountCode {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code          String       @unique @db.VarChar(50)
  discountType  DiscountType @map("discount_type")
  discountValue Decimal      @map("discount_value") @db.Decimal(10, 2)
  maxUses       Int?         @map("max_uses")
  usedCount     Int          @default(0) @map("used_count")
  validUntil    DateTime?    @map("valid_until") @db.Timestamptz
  isActive      Boolean      @default(true) @map("is_active")
  createdAt     DateTime     @default(now()) @map("created_at") @db.Timestamptz
  createdBy     String       @map("created_by") @db.Uuid

  creator User  @relation("CreatedBy", fields: [createdBy], references: [id])
  payments Payment[]

  @@map("discount_codes")
}

model Ticket {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  ticketTypeId            String            @map("ticket_type_id") @db.Uuid
  userId                  String            @map("user_id") @db.Uuid
  paymentId               String?           @map("payment_id") @db.Uuid
  unitPriceCents          Int               @map("unit_price_cents")
  ticketCode              String            @unique @map("ticket_code") @db.VarChar(100)
  qrToken                 String?           @unique @map("qr_token") @db.Text
  status                  TicketStatus
  reserveExpiresAt        DateTime?         @map("reserve_expires_at") @db.Timestamptz
  purchasedAt             DateTime?         @map("purchased_at") @db.Timestamptz
  cancelledAt             DateTime?         @map("cancelled_at") @db.Timestamptz
  confirmationRequestedAt DateTime?         @map("confirmation_requested_at") @db.Timestamptz
  checkedInAt             DateTime?         @map("checked_in_at") @db.Timestamptz
  checkedInBy             String?           @map("checked_in_by") @db.Uuid
  createdAt               DateTime          @default(now()) @map("created_at") @db.Timestamptz

  ticketType   TicketType    @relation(fields: [ticketTypeId], references: [id])
  user         User          @relation(fields: [userId], references: [id])
  checker      User?         @relation("CheckedInBy", fields: [checkedInBy], references: [id])
  payment      Payment?      @relation(fields: [paymentId], references: [id])

  @@index([userId])
  @@index([ticketTypeId])
  @@index([paymentId])
  @@index([status])
  @@map("tickets")
}

model Payment {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId          String        @map("user_id") @db.Uuid
  provider        String        @db.VarChar(50)
  providerTxId    String?       @map("provider_tx_id") @db.VarChar(255)
  subtotalCents   Int           @map("subtotal_cents")
  discountCents   Int           @default(0) @map("discount_cents")
  totalCents      Int           @map("total_cents")
  discountCodeId  String?       @map("discount_code_id") @db.Uuid
  status          PaymentStatus @default(pending)
  createdBy       String?       @map("created_by") @db.Uuid
  metadata        Json?
  createdAt       DateTime      @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime      @updatedAt @map("updated_at") @db.Timestamptz

  user    User         @relation(fields: [userId], references: [id])
  creator User?        @relation("CreatedPayments", fields: [createdBy], references: [id])
  discountCode DiscountCode? @relation(fields: [discountCodeId], references: [id])
  tickets Ticket[]

  @@index([userId])
  @@map("payments")
}
