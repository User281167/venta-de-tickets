generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  super_admin
  organizer
  staff
  checker
}

enum EventStatus {
  draft
  published
  finished
  cancelled
}

enum TicketStatus {
  reserved
  active
  used
  cancelled
  expired
  confirmed
}

enum PaymentStatus {
  pending
  completed
  failed
  refunded
}

enum DiscountType {
  percentage
  fixed
}

enum PolicyType {
  privacy_policy
  terms_of_service
}

enum SurveyType {
  onboarding
  event_survey
}

model User {
  id        String    @id @default(uuid()) @db.Uuid
  fullName  String    @map("full_name") @db.VarChar(150)
  email     String    @unique @db.VarChar(255)
  phone     String?   @db.VarChar(20)
  role      UserRole?
  isActive  Boolean   @default(true) @map("is_active")
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  // Auth gestionada por Supabase Auth (incluye proveedores sociales).
  // Este id debe coincidir con el id del usuario en auth.users (trigger de sincronización).

  privacyAcceptances PrivacyAcceptance[]
  tickets            Ticket[]
  payments           Payment[]
  surveyResponses    SurveyResponse[]
  checkedInTickets   Ticket[]          @relation("CheckedInBy")

  @@map("users")
}

model PrivacyAcceptance {
  id            String     @id @default(uuid()) @db.Uuid
  userId        String     @map("user_id") @db.Uuid
  policyVersion String     @map("policy_version") @db.VarChar(20)
  policyType    PolicyType @map("policy_type")
  acceptedAt    DateTime   @default(now()) @map("accepted_at") @db.Timestamptz
  ipAddress     String     @map("ip_address") @db.Inet
  userAgent     String     @map("user_agent")

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@map("privacy_acceptances")
}

model Event {
  id          String      @id @default(uuid()) @db.Uuid
  title       String      @db.VarChar(200)
  description String?     @db.Text
  location    String?     @db.VarChar(255)
  prefix      String?     @db.VarChar(10)
  eventDate   DateTime    @map("event_date") @db.Timestamptz
  doorsOpenAt DateTime?   @map("doors_open_at") @db.Timestamptz
  saleEndsAt  DateTime?   @map("sale_ends_at") @db.Timestamptz
  status      EventStatus
  createdAt   DateTime    @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime    @updatedAt @map("updated_at") @db.Timestamptz

  ticketTypes     TicketType[]
  discountCodes   DiscountCode[]
  tickets         Ticket[]
  surveyResponses SurveyResponse[]

  @@map("events")
}

model TicketType {
  id            String   @id @default(uuid()) @db.Uuid
  eventId       String   @map("event_id") @db.Uuid
  name          String   @db.VarChar(100)
  description   String?
  price         Decimal  @db.Decimal(12, 2)
  quantityTotal Int      @map("quantity_total")
  quantitySold  Int      @default(0) @map("quantity_sold")
  maxPerUser    Int?     @map("max_per_user")
  saleEndsAt    DateTime? @map("sale_ends_at") @db.Timestamptz
  isActive      Boolean  @default(true) @map("is_active")
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt     DateTime @updatedAt @map("updated_at") @db.Timestamptz

  event   Event    @relation(fields: [eventId], references: [id])
  tickets Ticket[]

  @@index([eventId])
  @@map("ticket_types")
}

model DiscountCode {
  id            String       @id @default(uuid()) @db.Uuid
  eventId       String       @map("event_id") @db.Uuid
  code          String       @unique @db.VarChar(50)
  discountType  DiscountType @map("discount_type")
  discountValue Decimal      @map("discount_value") @db.Decimal(10, 2)
  maxUses       Int?         @map("max_uses")
  usedCount     Int          @default(0) @map("used_count")
  validUntil    DateTime?    @map("valid_until") @db.Timestamptz
  isActive      Boolean      @default(true) @map("is_active")
  createdAt     DateTime     @default(now()) @map("created_at") @db.Timestamptz

  event   Event    @relation(fields: [eventId], references: [id])
  tickets Ticket[]

  @@index([eventId])
  @@map("discount_codes")
}

model Ticket {
  id               String       @id @default(uuid()) @db.Uuid
  ticketTypeId     String       @map("ticket_type_id") @db.Uuid
  eventId          String       @map("event_id") @db.Uuid
  userId           String       @map("user_id") @db.Uuid
  discountCodeId   String?      @map("discount_code_id") @db.Uuid
  discountApplied  Decimal?     @map("discount_applied") @db.Decimal(10, 2)
  ticketCode       String       @unique @map("ticket_code") @db.VarChar(100)
  qrToken          String?      @unique @map("qr_token") @db.Text
  status           TicketStatus
  reserveExpiresAt DateTime?    @map("reserve_expires_at") @db.Timestamptz
  purchasedAt      DateTime?    @map("purchased_at") @db.Timestamptz
  cancelledAt      DateTime?    @map("cancelled_at") @db.Timestamptz
  checkedInAt      DateTime?    @map("checked_in_at") @db.Timestamptz
  checkedInBy      String?      @map("checked_in_by") @db.Uuid
  createdAt        DateTime     @default(now()) @map("created_at") @db.Timestamptz

  ticketType   TicketType    @relation(fields: [ticketTypeId], references: [id])
  event        Event         @relation(fields: [eventId], references: [id])
  user         User          @relation(fields: [userId], references: [id])
  discountCode DiscountCode? @relation(fields: [discountCodeId], references: [id])
  checker      User?         @relation("CheckedInBy", fields: [checkedInBy], references: [id])
  payment      Payment?

  @@index([eventId])
  @@index([userId])
  @@index([ticketTypeId])
  @@index([status])
  @@map("tickets")
}

model Payment {
  id               String        @id @default(uuid()) @db.Uuid
  ticketId         String        @unique @map("ticket_id") @db.Uuid
  userId           String        @map("user_id") @db.Uuid
  amount           Decimal       @db.Decimal(12, 2)
  currency         String        @default("COP") @db.VarChar(10)
  paymentMethod    String        @map("payment_method") @db.VarChar(50)
  gatewayReference String?       @map("gateway_reference") @db.VarChar(200)
  status           PaymentStatus
  paidAt           DateTime?     @map("paid_at") @db.Timestamptz
  createdAt        DateTime      @default(now()) @map("created_at") @db.Timestamptz

  ticket Ticket @relation(fields: [ticketId], references: [id])
  user   User   @relation(fields: [userId], references: [id])

  @@index([userId])
  @@map("payments")
}

model SurveyResponse {
  id          String     @id @default(uuid()) @db.Uuid
  userId      String?    @map("user_id") @db.Uuid
  eventId     String?    @map("event_id") @db.Uuid
  surveyType  SurveyType @map("survey_type")
  responses   Json       @db.JsonB
  submittedAt DateTime   @default(now()) @map("submitted_at") @db.Timestamptz

  event Event? @relation(fields: [eventId], references: [id])
  user  User?  @relation(fields: [userId], references: [id])

  @@unique([userId, surveyType], name: "user_survey_type_unique")
  @@index([eventId])
  @@map("survey_responses")
}
